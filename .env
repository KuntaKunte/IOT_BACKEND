#**********************************************************************************************************#

# Environment Configuration Template for IoT Platform Features

# ==========================================
# ALERT NOTIFICATION SERVICE
# ==========================================

# Email/SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mchokoe1@gmail.com
SMTP_PASS=

# Email sender address
SMTP_FROM=mchokoe1@gmail.com

# Alert Email Recipients (comma-separated)
# These are default recipients for all alerts
ALERT_EMAIL_ALL=chokoetechnologies@gmail.com

# Specific alert type recipients
ALERT_EMAIL_OFFLINE=chokoetechnologies@gmail.com
ALERT_EMAIL_BATTERY=chokoetechnologies@gmail.com

# ==========================================
# WEBHOOK NOTIFICATIONS (Optional)
# ==========================================

# Webhook URL for alert notifications (e.g., Slack, Teams, custom service)
WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Webhook authentication token (if required)
WEBHOOK_SECRET=your-webhook-secret-token

# ==========================================
# BATTERY CONFIGURATION
# ==========================================

# Default battery thresholds
# Critical alert threshold (percentage)
BATTERY_CRITICAL_PERCENTAGE=20

# Warning threshold (percentage)
BATTERY_WARNING_PERCENTAGE=40

# Default battery voltage range (for 24V Li-ion system)
BATTERY_MIN_VOLTAGE=18
BATTERY_MAX_VOLTAGE=28.8

# ==========================================
# SITE OFFLINE DETECTION
# ==========================================

# Minutes before a site is considered offline
SITE_OFFLINE_THRESHOLD_MINUTES=60

# Check interval for offline sites (milliseconds)
SITE_STATUS_CHECK_INTERVAL=300000

# ==========================================
# DATABASE & MQTT
# ==========================================

#DB_URL=postgresql://user:password@postgres:5432/iot_db
DB_URL=postgres://iot:iotpass@postgres:5432/iotdb
MQTT_URL=mqtt://mosquitto:1883

# ==========================================
# API & SECURITY
# ==========================================

NODE_ENV=production
API_KEY=your-secure-api-key-here

ADMIN_USERNAME=admin
ADMIN_PASSWORD=TestPassword

# ==========================================
# WEEKLY REPORTS
# ==========================================

# Enable automatic weekly report generation
ENABLE_AUTO_REPORTS=true

# Day of week for automatic report generation (0-6, where 0 is Sunday)
AUTO_REPORT_DAY=1

# Hour of day for automatic report generation (0-23, UTC)
AUTO_REPORT_HOUR=0



